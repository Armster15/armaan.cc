---
import { Image } from "astro:assets";

import Layout from "$/components/Layout.astro";
import Link from "$/components/Link.astro";
import List from "$/components/List.astro";
import ListItem from "$/components/ListItem.astro";

import PfpIcon from "$/icons/icon.svg";
import MichiganIcon from "$/icons/michigan.svg";
import ReplitIcon from "$/icons/replit.svg";
import CinnamorollImg from "$/images/cinnamoroll.jpg";
---

<Layout
  seo={{
    title: "Armaan Aggarwal",
  }}
>
  <h1 class="sr-only">Home</h1>

  <div class="space-y-6 leading-7 text-pretty sm:leading-8">
    <p id="bessy-notice" class="text-sm sm:text-base" hidden="" data-nosnippet>
      ‼️ Please do not contact me about Bessy; I sold it and am no longer involved with it :)
    </p>

    <p>
      I'm a 19-year-old software engineer in San Francisco. I'm currently working full-time at
      <Link
        class="whitespace-nowrap"
        href="https://replit.com"
        target="_blank"
        data-s-event="home-replit-click"
      >
        <ReplitIcon
          aria-hidden="true"
          class="mr-[3px] ml-px inline-block h-[1.1em] w-[1.1em] -translate-y-px p-[1.5px]"
        />{"Replit"}
      </Link>.
    </p>

    <p>
      I spent my past lives in edtech. I previously created <Link
        href="https://www.bessy.io"
        target="_blank"
        data-s-event="home-bessy-click">Bessy</Link
      >, an app for students that I exited shortly after graduating high school. I was also the
      founding engineer at <Link
        href="https://coconote.app"
        target="_blank"
        data-s-event="home-coconote-click">Coconote</Link
      >, a consumer AI company that was acquired by <Link
        href="https://quizlet.com"
        target="_blank"
        data-s-event="home-quizlet-click">Quizlet</Link
      >.
    </p>

    <div class="space-y-8">
      <div class="space-y-2">
        <p>Other things about me:</p>

        <List>
          <ListItem>
            I'm fairly involved with open source, <Link
              href="https://github.com/Armster15?tab=repositories&q=expo&sort=stargazers"
              data-s-event="home-expo-click">particularly</Link
            >
            <Link
              href="https://github.com/bluesky-social/social-app/pull/7523"
              data-s-event="home-expo-click">around</Link
            >
            <Link href="https://github.com/expo/expo/pull/32567" data-s-event="home-expo-click"
              >Expo</Link
            >
            <Link href="https://github.com/Armster15/expo-xml-font" data-s-event="home-expo-click"
              >and</Link
            >
            <Link
              href="https://github.com/search?q=is%3Apr+author%3AArmster15+react+native&type=pullrequests"
              data-s-event="home-expo-click">React Native</Link
            >
          </ListItem>

          <ListItem>
            My <Link
              class="whitespace-nowrap"
              href="/icon.svg"
              target="_blank"
              data-s-event="home-old-pfp-click"
            >
              <PfpIcon
                aria-hidden="true"
                class="mr-[4px] ml-[2px] inline-block h-[1em] w-[1em] -translate-y-px rounded-full"
              />{"old profile picture"}
            </Link> was an SVG I hand-wrote from scratch (inspect element to see the code!)
          </ListItem>

          <ListItem>
            I also hand-wrote <Link
              href="https://github.com/Armster15/armaan.cc/blob/main/src/styles/globals.css#L15"
              data-s-event="home-gh-oklch-click">all the colors on this website</Link
            > (shout-out <Link
              href="https://evilmartians.com/chronicles/oklch-in-css-why-quit-rgb-hsl"
              data-s-event="home-evilmartians-oklch-click">OKLCH</Link
            >)
          </ListItem>

          <ListItem>
            I love Taco Bell but strongly <Link
              href="https://en.wikipedia.org/wiki/OR6A2"
              target="_blank"
              data-s-event="home-cilantro-click"
            >
              {"dislike cilantro"}
            </Link>
          </ListItem>

          <ListItem>
            I may or may not hoard too much <Link
              class="whitespace-nowrap"
              href="https://mgoblue.com"
              target="_blank"
              data-s-event="home-michigan-click"
            >
              <MichiganIcon
                aria-hidden="true"
                class="mr-[4px] ml-[2px] inline-block h-[1em] w-[1em] -translate-y-px rounded-xs"
              />{"Michigan Wolverines"}
            </Link> merch
          </ListItem>
        </List>
      </div>
    </div>
  </div>
</Layout>

<script>
  const bessyNotice = document.getElementById("bessy-notice");
  if (bessyNotice && document.referrer.includes("bessy.io")) {
    bessyNotice.removeAttribute("hidden");
  }
</script>
