---
import type { HTMLAttributes } from "astro/types";

type InputProps = Omit<HTMLAttributes<"input">, "type" | "min" | "max" | "step" | "value">;

export interface Props extends InputProps {
  value?: number | string;
  label?: string;
}

const DEFAULT_VALUE = "85";

const normalizeHue = (value: Props["value"], fallback = DEFAULT_VALUE) => {
  const hue = Number(value);
  if (!Number.isFinite(hue)) return fallback;
  return String(((Math.round(hue) % 360) + 360) % 360);
};

const { class: className, value, label, style, title, ...props } = Astro.props;

const normalizedValue = normalizeHue(value);
const ariaLabel = label ?? props["aria-label"] ?? "Hue";
const inputTitle = label ?? title ?? ariaLabel;
const initializesFromRoot = value == null;
const inputStyle = [`--hue-slider-fill: oklch(90% 75% ${normalizedValue})`, style]
  .filter(Boolean)
  .join("; ");
---

<input
  type="range"
  class:list={[
    "hue-slider m-0 block h-4 w-full appearance-none rounded-full border border-[Canvas] bg-[Canvas]",
    "[background-image:linear-gradient(to_right_in_oklch_longer_hue,oklch(90%_75%_0),oklch(90%_75%_360))]",
    "[box-shadow:inset_0_0_0_1px_color-mix(in_oklab,CanvasText,transparent_94%)]",
    "[color-scheme:light_dark] [forced-color-adjust:none]",
    "disabled:cursor-not-allowed disabled:opacity-60",
    className,
  ]}
  data-default-hue={DEFAULT_VALUE}
  data-hue-slider
  data-initializes-from-root={initializesFromRoot ? "true" : undefined}
  min="0"
  max="359"
  step="1"
  value={normalizedValue}
  aria-label={ariaLabel}
  style={inputStyle}
  title={inputTitle}
  {...props}
/>

<script>
  const normalizeHue = (value: string, fallback = 85) => {
    const hue = Number(value);
    if (!Number.isFinite(hue)) return fallback;
    return ((Math.round(hue) % 360) + 360) % 360;
  };

  const syncHueSlider = (slider: HTMLInputElement, nextValue: string) => {
    const fallback = Number(slider.dataset.defaultHue ?? "85");
    const hue = normalizeHue(nextValue, fallback);

    slider.value = String(hue);
    slider.style.setProperty("--hue-slider-fill", `oklch(90% 75% ${hue})`);
    document.documentElement.style.setProperty("--shades-hue", String(hue));
  };

  document.querySelectorAll("input[data-hue-slider]").forEach((slider) => {
    if (!(slider instanceof HTMLInputElement) || slider.dataset.hueSliderBound === "true") return;

    slider.dataset.hueSliderBound = "true";

    const initialValue =
      slider.dataset.initializesFromRoot === "true"
        ? getComputedStyle(document.documentElement).getPropertyValue("--shades-hue")
        : slider.value;

    syncHueSlider(slider, initialValue);
    slider.addEventListener("input", () => syncHueSlider(slider, slider.value));
  });
</script>

<style>
  .hue-slider::-webkit-slider-thumb,
  .hue-slider::-moz-range-thumb {
    cursor: grab;
    appearance: none;
    block-size: calc(1rem + 8px);
    inline-size: calc(1rem + 8px);
    border-radius: 999px;
    background: var(--hue-slider-fill);
    border: 4px solid white;
    box-shadow: 0 0 1px 1px rgb(0 0 0 / 25%);
    transform: scale(0.2);
    transition:
      transform 150ms cubic-bezier(0.25, 1, 0.5, 1),
      box-shadow 150ms cubic-bezier(0.25, 1, 0.5, 1),
      background 150ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .hue-slider::-moz-range-thumb {
    box-sizing: border-box;
  }

  .hue-slider:hover::-webkit-slider-thumb,
  .hue-slider:focus::-webkit-slider-thumb,
  .hue-slider:hover::-moz-range-thumb,
  .hue-slider:focus::-moz-range-thumb {
    transform: scale(1);
    box-shadow:
      0 0 1px 1px rgb(0 0 0 / 25%),
      inset 0 1px 2px rgb(0 0 0 / 15%);
  }

  .hue-slider:active::-webkit-slider-thumb,
  .hue-slider:active::-moz-range-thumb {
    cursor: grabbing;
  }

  .hue-slider:disabled::-webkit-slider-thumb,
  .hue-slider:disabled::-moz-range-thumb {
    cursor: not-allowed;
  }

  @media (prefers-reduced-motion: reduce) {
    .hue-slider::-webkit-slider-thumb,
    .hue-slider::-moz-range-thumb {
      transition: none;
    }
  }
</style>
